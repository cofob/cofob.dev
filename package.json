{
	"name": "cofob-ru",
	"type": "module",
	"version": "0.0.1",
	"license": "MIT",
	"description": "svelte-powered website",
	"homepage": "https://cofob.dev/",
	"engines": {
		"node": ">=24.11.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "DEPLOY_TARGET=node vite build",
		"build:static": "DEPLOY_TARGET=static vite build && cp ./build/200.html ./build/ipfs-404.html && cp ./build/200.html ./build/index.html && cp ./_headers ./build/_headers",
		"build:cloudflare": "DEPLOY_TARGET=cloudflare vite build",
		"preview": "vite preview",
		"postinstall": "svelte-kit sync",
		"test": "npm run check && npm run lint && npm run test:smoke",
		"test:smoke": "npm run build && node scripts/smoke-node.mjs",
		"test:static": "npm run build:static && node scripts/check-static.mjs",
		"test:cloudflare": "npm run build:cloudflare && node scripts/smoke-cloudflare.mjs",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"start": "node build"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@sveltejs/adapter-cloudflare": "7.2.9",
		"@sveltejs/adapter-node": "5.5.7",
		"@sveltejs/adapter-static": "3.0.10",
		"@sveltejs/kit": "2.69.2",
		"@sveltejs/vite-plugin-svelte": "7.2.0",
		"@tailwindcss/postcss": "4.3.2",
		"@types/node": "26.1.1",
		"@types/nprogress": "0.2.3",
		"eslint": "10.6.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.20.0",
		"globals": "17.7.0",
		"postcss": "8.5.16",
		"prettier": "3.9.5",
		"prettier-plugin-svelte": "4.1.1",
		"svelte": "5.56.4",
		"svelte-check": "4.7.2",
		"tailwindcss": "4.3.2",
		"typescript": "6.0.3",
		"typescript-eslint": "8.63.0",
		"vite": "8.1.4",
		"wrangler": "4.110.0"
	},
	"dependencies": {
		"nprogress": "0.2.0"
	},
	"overrides": {
		"cookie": "0.7.2"
	},
	"allowScripts": {
		"esbuild@0.28.1": true,
		"sharp@0.34.5": true,
		"workerd@1.20260708.1": true
	}
}
