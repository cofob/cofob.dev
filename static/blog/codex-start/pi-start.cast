[0.011, "o", "Usage:\r\n  pi-start [pi-start options] <preset_name> [pi args...]\r\n  pi-start [pi-start options] [-- pi args...]  # uses .git/pi-defaults\r\n  pi-start [pi-start options] --commit\r\n  pi-start [pi-start options] --squash\r\n  pi-start [pi-start options] --move\r\n  pi-start [pi-start options] --edit\r\n  pi-start [pi-start options] --shell [<preset_name>]\r\n  pi-start --cleanup\r\n\r\npi-start options:\r\n  -n, --name <name>    Worktree name. Branch will be pi/<name>\r\n  --no-worktree        Mount current directory directly; do not create a Git worktree\r\n  --worktree           Require Git worktree mode\r\n  --no-network         Use the default allowlisted HTTP/HTTPS proxy network\r\n  --commit             Run interactive git commit in the selected worktree\r\n  --squash             Autosave worktree changes, squash them into current branch, then open git commit editor\r\n  --move               Apply all worktree changes into current branch without committing\r\n  --edit               Open the selected worktree in Zed\r\n  --shell         "]
[0.000, "o", "     Start or attach to an interactive Bash shell container\r\n  --cleanup            Remove stale pi-start allowlist proxies and networks\r\n  -h, --help           Show help\r\n\r\nProject defaults:\r\n  If <preset_name> is omitted inside a Git work tree, pi-start reads\r\n  <project>/.git/pi-defaults. The file may contain either rust or preset=rust.\r\n\r\nEnvironment:\r\n  PI_PRESETS_DIR                 Defaults to ~/.pi-presets\r\n  PI_START_REBUILD               If 1, rebuild image before running\r\n  PI_START_NO_TTY                If 1, do not pass -it to docker run\r\n  PI_START_WORKDIR               Container workdir, defaults to /workspace\r\n  PI_START_IMAGE_PREFIX          Defaults to pi-preset\r\n\r\n  PI_START_WORKTREE              auto|0|1, defaults to auto\r\n  PI_START_WORKTREE_BASE         Defaults to ~/.worktrees\r\n\r\n  PI_START_NETWORK               host|default|none|allowlist, defaults to allowlist\r\n  PI_START_ALLOWED_HOSTS         Host allowlist for none/allowlist mode\r\n\r\n  PI_START_FORWARD_SSH           1|0, defaults to "]
[0.000, "o", "1\r\n  PI_START_FORWARD_GPG           1|0, defaults to 1\r\n\r\n  PI_START_KNOWN_HOSTS           1|0, defaults to 1\r\n  PI_START_KNOWN_HOSTS_FILE      Defaults to ~/.ssh/known_hosts\r\n  PI_START_CONTAINER_SSH_DIR     Defaults to /home/piuser/.ssh\r\n  PI_START_SSH_USER              Defaults to current host user\r\n  PI_START_RUNTIME_DIR           Defaults to ~/.cache/pi-start\r\n\r\n  PI_START_AGENT_HOME            1|0, defaults to 1\r\n  PI_START_AGENT_HOME_VOLUME     Defaults to pi-agent-home\r\n  PI_START_AGENT_HOME_DIR        Defaults to /home/piuser/.pi/agent\r\n\r\n  PI_START_NPM_CACHE             1|0, defaults to 1\r\n  PI_START_NPM_CACHE_VOLUME      Defaults to pi-npm-cache-shared\r\n  PI_START_NPM_CACHE_DIR         Defaults to /home/piuser/.cache/npm\r\n"]
[0.002, "o", "\u001b[1m\u001b[7m%\u001b[27m\u001b[1m\u001b[0m                                                                                                                                                                                                       \r \r"]
